{
  "name": "Lab Stock Entry",
  "module": "pharma_rd",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "format:LSE-.####",
  "fields": [
    {"fieldname": "item",         "fieldtype": "Link",    "label": "Item",             "options": "Lab Item", "reqd": 1, "in_list_view": 1},
    {"fieldname": "entry_type",   "fieldtype": "Select",  "label": "Type",
      "options": "Stock In\nStock Out\nAdjustment",           "reqd": 1, "in_list_view": 1},
    {"fieldname": "quantity",     "fieldtype": "Float",   "label": "Quantity",         "reqd": 1, "in_list_view": 1},
    {"fieldname": "batch_no",      "fieldtype": "Data",    "label": "Manufacturer Batch No"},
    {"fieldname": "expiry_date",   "fieldtype": "Date",    "label": "Expiry Date",      "in_list_view": 1},
    {"fieldname": "posting_date", "fieldtype": "Date",    "label": "Posting Date",     "default": "Today", "reqd": 1},
    {"fieldname": "performed_by",  "fieldtype": "Link",    "label": "Performed By",     "options": "User", "default": "Session User"},
    {"fieldname": "project",      "fieldtype": "Link",    "label": "Link to Project",  "options": "Research Project"},
    {"fieldname": "remarks",      "fieldtype": "Small Text","label": "Remarks"}
  ],
  "permissions": [
    {"role": "Pharma Admin", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1},
    {"role": "Lab Manager",  "read": 1, "write": 1, "create": 1, "submit": 1}
  ]
}
